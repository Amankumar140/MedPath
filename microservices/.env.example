# Framework Settings
PROJECT_NAME="MedPath Backend Engine"
API_V1_STR="/api/v1"

# Databases & Infrastructure Caching
# URL-encode any '@' in passwords to '%40'. Remove literal square brackets if they were placeholders!
DATABASE_URL=postgres://username:password@hostname:port/dbname?sslmode=require
REDIS_URL=redis://default:password@hostname:port

# Asynchronous Distributed Workers
CELERY_BROKER_URL=redis://default:password@hostname:port
CELERY_RESULT_BACKEND=redis://default:password@hostname:port/2

# Database Provider (Supabase Integration)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# Authentication Guard (Firebase Admin SDK)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-firebase-private-key\n-----END PRIVATE KEY-----\n"

# External Search & Intelligence Feeds
TAVILY_API_KEY=your-tavily-api-key
GOOGLE_MAPS_KEY=your-google-maps-api-key

# Core Analytical AI Routing Configuration
PRIMARY_LLM="gemini"
GEMINI_API_KEY=your-gemini-api-key
MISTRAL_API_KEY=your-mistral-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key